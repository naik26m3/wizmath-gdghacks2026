rules_version = '2';

// Authenticated users only; each user may write their own user + leaderboard row.
// XP is client-authoritative for the hackathon (see BLUEPRINT — no Cloud Functions).

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Activities — anyone can read; signed-in users can publish; star toggle by any authed user;
    // title/description edits only by the author; delete only by the author.
    match /activities/{activityId} {
      allow read: if true;
      allow create: if true;
      allow update: if request.auth != null && (
        // Anyone signed in can star/unstar (only stars + starredBy fields)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stars', 'starredBy'])
        ||
        // The author can edit title and/or description (only those fields)
        (resource.data.authorUid == request.auth.uid
         && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'description']))
      );
      allow delete: if request.auth != null && resource.data.authorUid == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
